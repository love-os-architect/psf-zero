import torch
import pennylane as qml
from pennylane.tape import QuantumTape
import numpy as np

# =====================================================================
# 1. SU(2) → ZYZ Euler Decomposition (Stable & Exact)
# =====================================================================
def su2_to_euler(U: np.ndarray) -> tuple[float, float, float]:
    """Decompose SU(2) unitary into Z-Y-Z Euler angles for qml.Rot"""
    if not np.allclose(np.linalg.det(U), 1.0, atol=1e-8):
        raise ValueError("Matrix is not in SU(2)")

    a, b = U[0, 0], U[0, 1]
    theta = 2 * np.arccos(np.clip(np.abs(a), -1.0, 1.0))

    if np.isclose(theta, 0.0):
        phi = 0.0
        lam = np.angle(a)
    else:
        phi = np.angle(b) - np.angle(a)
        lam = np.angle(b) + np.angle(a)

    return float(phi % (2*np.pi)), float(theta), float(lam % (2*np.pi))


