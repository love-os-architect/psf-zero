# 1. Setup
import numpy as np
from qiskit import QuantumCircuit
from qiskit_ibm_runtime import QiskitRuntimeService, Estimator
from qiskit.transpiler import PassManager, generate_preset_pass_manager
from qiskit.circuit.library import XXPlusYYGate
from psf_zero import SU4GeodesicPSFUnitarySynthesis, GeodesicPSFHyper
import matplotlib.pyplot as plt

service = QiskitRuntimeService()
backend = service.backend("ibm_brisbane")
print("Connected to:", backend.name)

# 2. Realistic Target Circuit (Quantum Chemistry)
theta = np.pi / 3
target_unitary = XXPlusYYGate(theta).to_matrix()
qc = QuantumCircuit(2)
qc.append(target_unitary, [0, 1])
qc.measure_all()

# 3. Run Benchmark (Default vs PSF-Zero)
def benchmark(use_psf: bool = False):
    if use_psf:
        # THE Z-AXIS PROOF: Zero randomness, zero learning rates. Only geometric tolerance.
        hyper = GeodesicPSFHyper(tol=1e-9)
        synth = SU4GeodesicPSFUnitarySynthesis(hyper)
        optimized_qc = synth.run(target_unitary)
        label = "PSF-Zero (Deterministic)"
    else:
        optimized_qc = qc
        label = "Default Qiskit"

    # Hardware transpilation
    transpiler = generate_preset_pass_manager(
        optimization_level=3, 
        backend=backend,
        basis_gates=['rx', 'ry', 'rz', 'rxx', 'ryy', 'rzz']
    )
    isa_circuit = transpiler.run(optimized_qc)

    # Run on real device
    estimator = Estimator(backend=backend)
    job = estimator.run([isa_circuit], [[1, 0, 0, 0]])  # |00> expectation as proxy
    result = job.result()
    
    fidelity_proxy = result.values[0]
    depth = isa_circuit.depth()
    
    # Count physical entangling gates
    entangling_gates = sum([
        isa_circuit.count_ops().get('rzz', 0),
        isa_circuit.count_ops().get('rxx', 0),
        isa_circuit.count_ops().get('ryy', 0)
    ])
    
    return label, fidelity_proxy, depth, entangling_gates, isa_circuit

# Execute
print("Running Default Qiskit...")
default_label, default_fid, default_depth, default_ent, _ = benchmark(False)

print("\nRunning PSF-Zero...")
psf_label, psf_fid, psf_depth, psf_ent, _ = benchmark(True)

print("\n=== Results on ibm_brisbane ===")
print(f"{default_label:25} | Fidelity Proxy: {default_fid:.4f} | Depth: {default_depth} | Entangling: {default_ent}")
print(f"{psf_label:25} | Fidelity Proxy: {psf_fid:.4f} | Depth: {psf_depth} | Entangling: {psf_ent}")

# 4. Visualization
labels = [default_label, psf_label]
fids = [default_fid, psf_fid]
depths = [default_depth, psf_depth]
ent = [default_ent, psf_ent]

fig, ax1 = plt.subplots(figsize=(11, 6))
bars = ax1.bar(labels, fids, color=['#e74c3c', '#3498db'], alpha=0.85)
ax1.set_ylabel('Fidelity Proxy (higher is better)', color='blue')
ax1.tick_params(axis='y', labelcolor='blue')

ax2 = ax1.twinx()
ax2.plot(labels, depths, 'o-', color='green', linewidth=3, markersize=10, label='Circuit Depth')
ax2.plot(labels, ent, 's--', color='purple', linewidth=3, markersize=8, label='Entangling Gates')
ax2.set_ylabel('Depth / Entangling Gates (lower is better)', color='green')

plt.title('PSF-Zero vs Default Qiskit on Real Hardware (ibm_brisbane)\n'
          '— Demonstrating Deterministic O(1) Synthesis —')
plt.grid(True, alpha=0.3)
plt.legend(loc='upper center')
plt.tight_layout()
plt.show()
